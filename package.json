{
  "name": "@flowstate/monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=20 <23"
  },
  "workspaces": [
    "apps/*",
    "packages/common/env"
  ],
  "scripts": {
    "preinstall": "npx only-allow yarn",
    "dev:api": "yarn workspace @flowstate/api dev",
    "dev:bot": "yarn workspace @flowstate/bot dev",
    "dev:landing": "yarn workspace landing dev",
    "dev:coach": "yarn workspace coach-portal dev",
    "build:api": "yarn workspace @flowstate/api build",
    "build:bot": "yarn workspace @flowstate/bot build",
    "build:landing": "yarn workspace landing build",
    "build:coach": "yarn workspace coach-portal build",
    "lint-staged": "lint-staged",
    "lint:ox": "oxlint --deny-warnings"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,jsx}": [
      "oxlint --deny-warnings --fix"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxlint": "^1.52.0",
    "typescript": "^5.9.3"
  }
}
